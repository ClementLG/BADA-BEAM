# ==========================================
# Bada-Beam Environment Configuration
# ==========================================

# FLASK_ENV can be "development" or "production"
FLASK_ENV=production

# Server binding and port
HOST=0.0.0.0
PORT=5000

# Set DEBUG to true for development, false for production
DEBUG=false

# Flask Secret Key for session signing and security (Flask-Talisman, etc.)
# Run `python -c 'import secrets; print(secrets.token_hex(32))'` to generate a new key
# SECRET_KEY=your-super-secret-key-here

